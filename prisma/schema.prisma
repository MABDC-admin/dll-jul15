generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  name           String
  role           String          // "ADMIN", "PRINCIPAL", "TEACHER"
  teacherProfile TeacherProfile?
  notifications  Notification[]
}

model TeacherProfile {
  id             String      @id @default(cuid())
  userId         String      @unique
  user           User        @relation(fields: [userId], references: [id])
  department     String
  gradeLevels    String      // JSON string array
  sections       String      // JSON string array
  subjects       String      // JSON string array
  schedule       String
  totalSubmitted Int         @default(0)
  approved       Int         @default(0)
  forRevision    Int         @default(0)
  missing        Int         @default(0)
  complianceRate Float       @default(0)
  status         String
  avatar         String

  lessonLogs     LessonLog[]
  schedules      Schedule[]
  anecdotalRecords AnecdotalRecord[]
  subjectLoads   TeacherSubjectLoad[]
  viewedAnnouncements String[] // Array of Announcement IDs
}

model LessonLog {
  id               String   @id @default(cuid())
  teacherProfileId String
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id])
  learningArea     String
  teachingDates    String
  submittedDate    DateTime @default(now())
  status           String   // "Pending Review", "Approved", "For Revision"
  originalFilename String
  fileVersion      String
  schoolYear       String
  term             String
  weekNumber       String
  timeliness       String
  remarks          String?
  approvedBy       String?
  approvedDate     DateTime?
  
  content          String   // JSON string
}

model Schedule {
  id               String   @id @default(cuid())
  teacherProfileId String
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id])
  day              String
  timeStart        String
  timeEnd          String
  gradeId          String
  sectionName      String
  subjectName      String
}

model Learner {
  id             String   @id @default(cuid())
  name           String
  gradeId        String
  gradeSection   String
  gpa            Float
  performance    String
  attendance     Float
  guardian       String
  contact        String
  riskLevel      String
  interventions  String   // JSON string array
  anecdotalRecords AnecdotalRecord[]
}

model GradeLevel {
  id       String @id
  name     String
  level    Int
  keyStage String
  count    Int      @default(0)
  sections String   @default("[]") // JSON string array of section names
  subjects String   @default("[]") // JSON string array of subject names
}

model Subject {
  id          String @id
  name        String
  code        String
  department  String
  type        String
  gradeLevels String @default("[]") // JSON string array of grade IDs or names
}

model AttendanceRecord {
  id             String   @id @default(cuid())
  date           String
  gradeId        String
  sectionName    String
  records        String   // JSON { studentId: "Present" | "Late" | "Absent" }
  submittedDate  DateTime @default(now())
}

model ChecklistRubric {
  id    String @id
  text  String
  value String
}

model AuditLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  user      String
  action    String
  type      String
}

model SystemConfig {
  id                  String @id @default("default")
  schoolYear          String
  term                String
  activeFramework     String
  subscriptionTier    String
  subscriptionStatus  String
  renewalDate         String
  allottedUsers       Int
  allottedLearners    Int
  storageAllotted     Float
  storageUsed         Float
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AnecdotalRecord {
  id                  String         @id @default(cuid())
  teacherProfileId    String
  teacherProfile      TeacherProfile @relation(fields: [teacherProfileId], references: [id])
  learnerId           String
  learner             Learner        @relation(fields: [learnerId], references: [id])
  incidentDate        DateTime
  recordType          String         @default("Neutral")
  severity            String         @default("Minor")
  incidentType        String         @default("Other")
  description         String
  actionTaken         String
  status              String         // "Pending Review", "Resolved"
  principalResolution String?
  submittedDate       DateTime       @default(now())
  resolvedDate        DateTime?
  resolvedBy          String?
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  mediaUrl  String?
  mediaType String?  // "image" or "video"
  isActive  Boolean  @default(true)
  publishAt DateTime @default(now())
  createdAt DateTime @default(now())
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  eventType   String   // "Holiday", "Event", "Academic", "Birthday", "Private"
  color       String
  isGlobal    Boolean  @default(true)
  ownerId     String?
  createdAt   DateTime @default(now())
}

model TeacherSubjectLoad {
  id               String         @id @default(cuid())
  teacherProfileId String
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  gradeId          String
  sectionName      String
  subjectName      String
}
